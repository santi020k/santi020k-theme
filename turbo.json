{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["CI", "NPM_TOKEN", "NODE_AUTH_TOKEN", "OVSX_PAT", "STARSHIP_BIN", "VSCE_PAT", "VITEST"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        "themes/*-bold-color-theme.json",
        "themes/*-italic-color-theme.json",
        "themes/santi020k-hc-light-color-theme.json"
      ],
      "outputLogs": "errors-only"
    },
    "santi020k-terminal-theme#build": {
      "outputs": ["alacritty/**", "assets/previews/**", "ghostty/**", "iterm2/**", "kitty/**", "starship/**", "wezterm/**", "windows-terminal/**"],
      "outputLogs": "errors-only"
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview": {
      "cache": false,
      "persistent": true
    },
    "package": {
      "dependsOn": ["build"],
      "outputs": ["*.vsix"],
      "outputLogs": "errors-only"
    },
    "validate:themes": {
      "dependsOn": ["build"],
      "outputs": [],
      "outputLogs": "errors-only"
    },
    "//#lint:knip": {
      "dependsOn": ["build"],
      "outputLogs": "errors-only"
    }
  },
  "futureFlags": {
    "errorsOnlyShowHash": true
  }
}
