{
  "name": "@santi020k/theme-core",
  "version": "0.0.0",
  "description": "Shared token and asset manifest helpers for Santi020k theme packages.",
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./types": {
      "types": "./types.d.ts",
      "import": "./types.js"
    },
    "./utils": {
      "types": "./utils.d.ts",
      "import": "./utils.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "index.d.ts",
    "index.js",
    "types.d.ts",
    "types.js",
    "utils.d.ts",
    "utils.js",
    "README.md"
  ],
  "scripts": {
    "build": "node --check index.js && node --check types.js && node --check utils.js",
    "validate": "pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@10.32.1",
  "license": "MIT",
  "author": {
    "name": "Santiago Molina",
    "url": "https://santi020k.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/santi020k/santi020k-theme",
    "directory": "packages/theme-core"
  },
  "bugs": {
    "url": "https://github.com/santi020k/santi020k-theme/issues"
  },
  "homepage": "https://theme.santi020k.com"
}
