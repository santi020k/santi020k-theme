{
  "name": "santi020k-chrome-theme",
  "version": "2.0.0",
  "packageManager": "pnpm@10.32.1",
  "private": true,
  "description": "Chrome browser theme matching the Santi020k palette.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm run package:dry",
    "dev": "pnpm run dev:dark",
    "dev:dark": "node scripts/prepare-dev-extension.mjs --variant=dark",
    "dev:light": "node scripts/prepare-dev-extension.mjs --variant=light",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "validate:a11y": "node scripts/validate-theme.mjs",
    "validate": "pnpm run lint && pnpm run validate:a11y && pnpm run package:dry",
    "sync:themes": "node scripts/sync-from-vscode-theme.mjs --variant=dark --write && node scripts/sync-from-vscode-theme.mjs --variant=light --write",
    "sync:assets": "node scripts/generate-ntp-image.mjs && node scripts/generate-ntp-image-light.mjs && node scripts/generate-store-assets-light.mjs",
    "sync:store-assets:light": "node scripts/generate-store-assets-light.mjs",
    "sync": "pnpm run sync:themes && pnpm run sync:assets",
    "package": "node scripts/package-extension.mjs",
    "package:dry": "node scripts/package-extension.mjs --dry-run",
    "publish:webstore": "node scripts/publish-webstore.mjs",
    "release": "pnpm run package && pnpm run publish:webstore"
  },
  "funding": "https://github.com/sponsors/santi020k",
  "dependencies": {
    "@santi020k/theme": "workspace:^"
  },
  "devDependencies": {
    "@santi020k/eslint-config-basic": "catalog:",
    "archiver": "catalog:",
    "eslint": "catalog:"
  }
}
