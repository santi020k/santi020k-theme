# Santi020k theme workspace environment template.
# Copy this file to .env for local release/deploy testing. Never commit real secret values.

# VS Code extension release credentials
# Used by: packages/santi020k-theme/scripts/publish-registries.mjs
# Project: packages/santi020k-theme, usually through root `pnpm run release`.
# VSCE_PAT publishes to the Visual Studio Marketplace.
VSCE_PAT=
# OVSX_PAT publishes to Open VSX.
OVSX_PAT=

# npm package release credentials
# Used by: scripts/publish-npm-packages.mjs
# Projects: packages/theme-core and packages/theme, usually through root `pnpm run release`.
# NPM_TOKEN publishes @santi020k/theme-core and @santi020k/theme to npm.
# Generate at https://www.npmjs.com/settings/<user>/tokens
NPM_TOKEN=

# Chrome Web Store release credentials
# Used by: packages/santi020k-chrome-theme/scripts/publish-webstore.mjs
# Project: packages/santi020k-chrome-theme, usually through root `pnpm run release:chrome`.
CHROME_WEBSTORE_PUBLISHER_ID=
# Full Google Cloud service account JSON key contents. Keep this on one line when using .env.
CHROME_WEBSTORE_SERVICE_ACCOUNT_JSON=
# Optional overrides. Defaults are the public dark/light listing IDs already in the package docs.
# CHROME_WEBSTORE_DARK_ITEM_ID=
# CHROME_WEBSTORE_LIGHT_ITEM_ID=
# Optional publish tuning.
# CHROME_WEBSTORE_PUBLISH_TYPE=DEFAULT_PUBLISH
# CHROME_WEBSTORE_BLOCK_ON_WARNINGS=true
# CHROME_WEBSTORE_SKIP_REVIEW=false
# CHROME_WEBSTORE_DEPLOY_PERCENTAGE=100

# GitHub release automation
# Used by: .github/workflows/release.yml and Changesets.
# Project: CI only; GitHub Actions provides this automatically.
# GITHUB_TOKEN=

# Website deployment credentials
# Used by: Cloudflare Pages deploy workflows.
# Projects: apps/website, apps/vscode-website, apps/chrome-website, and apps/iterm-website.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT_THEME_HUB=
CLOUDFLARE_PAGES_PROJECT_VSCODE=
CLOUDFLARE_PAGES_PROJECT_CHROME=
CLOUDFLARE_PAGES_PROJECT_ITERM=

# Legacy single-site website deployment
# Used by: old Cloudflare Pages setup before the hub/VS Code/Chrome split.
# Keep unset for the new multi-site architecture unless a legacy workflow still needs it.
# CLOUDFLARE_PAGES_PROJECT_NAME=

# Turbo remote cache
# Used by: `turbo run ...` when local remote cache access should match other Santi020k workspaces.
TURBO_TOKEN=
TURBO_TEAM=
TURBO_CONCURRENCY=10
TURBO_REMOTE_CACHE_TIMEOUT=30

# Local tooling
# Used by: packages/santi020k-chrome-theme/scripts/generate-store-assets-light.mjs when Chrome is not in the default macOS path.
# CHROME_BIN=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Used by: Husky during local setup or scripted release preparation when hooks should be skipped.
# HUSKY=0
