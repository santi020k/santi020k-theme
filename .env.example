# Santi020k theme workspace environment template.
# Copy this file to .env for local release/deploy testing. Never commit real secret values.

# VS Code extension release credentials
# Used by: packages/santi020k-theme/scripts/publish-registries.mjs
# Project: packages/santi020k-theme, usually through root `pnpm run release`.
VSCE_PAT=
OVSX_PAT=

# GitHub release automation
# Used by: .github/workflows/release.yml and Changesets.
# Project: CI only; GitHub Actions provides this automatically.
# GITHUB_TOKEN=

# Website deployment credentials
# Used by: future Cloudflare Pages deploy workflows.
# Projects: apps/website, apps/vscode-website, and apps/chrome-website.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT_THEME_HUB=
CLOUDFLARE_PAGES_PROJECT_VSCODE=
CLOUDFLARE_PAGES_PROJECT_CHROME=

# Legacy single-site website deployment
# Used by: old Cloudflare Pages setup before the hub/VS Code/Chrome split.
# Keep unset for the new multi-site architecture unless a legacy workflow still needs it.
# CLOUDFLARE_PAGES_PROJECT_NAME=

# Local tooling
# Used by: Husky during local setup or scripted release preparation when hooks should be skipped.
# HUSKY=0
