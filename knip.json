{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreBinaries": [
    "validate"
  ],
  "ignoreDependencies": [
    "ovsx"
  ],
  "workspaces": {
    ".": {
      "entry": [
        "package.json"
      ],
      "project": [
        "*.mjs"
      ]
    },
    "apps/website": {
      "entry": [
        "src/pages/*.astro"
      ],
      "ignore": [
        "src/main.js"
      ],
      "ignoreDependencies": [
        "@santi020k/theme"
      ],
      "project": [
        "src/**/*.astro",
        "src/**/*.js"
      ]
    },
    "apps/vscode-website": {
      "entry": [
        "package.json",
        "scripts/*.mjs",
        "src/pages/*.astro"
      ],
      "ignore": [
        "src/main.js"
      ],
      "ignoreDependencies": [
        "@santi020k/theme"
      ],
      "project": [
        "scripts/**/*.mjs",
        "src/**/*.astro",
        "tests/**/*.mjs",
        "src/**/*.js"
      ]
    },
    "apps/chrome-website": {
      "entry": [
        "src/pages/*.astro"
      ],
      "ignore": [
        "src/main.js"
      ],
      "ignoreDependencies": [
        "@santi020k/theme"
      ],
      "project": [
        "src/**/*.astro",
        "src/**/*.js"
      ]
    },
    "packages/santi020k-chrome-theme": {
      "entry": [
        "package.json"
      ],
      "project": [
        "scripts/**/*.mjs"
      ]
    },
    "packages/santi020k-theme": {
      "entry": [
        "package.json",
        "scripts/*.mjs"
      ],
      "project": [
        "scripts/**/*.mjs",
        "tests/**/*.mjs"
      ]
    },
    "packages/theme": {
      "entry": [
        "package.json"
      ],
      "ignoreIssues": {
        "tailwind.js": [
          "duplicates"
        ]
      }
    },
    "packages/theme-core": {
      "entry": [
        "package.json"
      ]
    }
  }
}
