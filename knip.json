{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreBinaries": [
    "validate"
  ],
  "ignoreDependencies": [
    "ovsx"
  ],
  "workspaces": {
    ".": {
      "entry": [
        "scripts/*.mjs"
      ],
      "project": [
        "scripts/**/*.mjs",
        "tests/**/*.mjs"
      ]
    },
    "apps/website": {
      "project": [
        "src/**/*.js"
      ]
    },
    "apps/vscode-website": {
      "project": [
        "src/**/*.js"
      ]
    },
    "packages/santi020k-chrome-theme": {
      "entry": [
        "package.json",
        "website/src/main.js",
        "website/vite.config.js"
      ],
      "project": [
        "scripts/**/*.mjs",
        "website/src/**/*.js"
      ]
    },
    "packages/santi020k-theme": {
      "entry": [
        "package.json"
      ]
    }
  }
}
