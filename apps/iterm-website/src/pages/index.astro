---
const structuredData = {
  '@context': 'https://schema.org', '@type': 'SoftwareApplication', name: 'Santi020k Theme for iTerm2',
  applicationCategory: 'DeveloperApplication', applicationSubCategory: 'Terminal Color Scheme', operatingSystem: 'macOS',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' }, url: 'https://iterm.santi020k.com/',
  downloadUrl: 'https://iterm.santi020k.com/themes/Santi020k%20Dark.itermcolors',
  description: 'Calm violet dark and light color presets for iTerm2, mapped from the Santi020k theme family.',
  author: { '@type': 'Person', name: 'Santiago Molina', url: 'https://santi020k.com' },
}
const structuredDataHtml = `<script type="application/ld+json">${JSON.stringify(structuredData)}</script>`
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>(function(){var s=localStorage.getItem('theme');var p=s==='light'||s==='dark'?s:window.matchMedia('(prefers-color-scheme: light)').matches?'light':'dark';document.documentElement.dataset.theme=p})()</script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Santi020k iTerm2 Theme — Dark and Light Terminal Presets</title>
    <link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600&family=Montserrat:wght@500;600;700;800&display=swap" rel="stylesheet">
    <meta name="description" content="Download dark and light Santi020k color presets for iTerm2. Calm indigo backgrounds, readable ANSI colors, and a focused violet cursor." />
    <meta name="author" content="Santiago Molina" /><meta name="language" content="en" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="color-scheme" content="dark light" /><link rel="canonical" href="https://iterm.santi020k.com/" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#0d0a15" media="(prefers-color-scheme: dark)" /><meta name="theme-color" content="#f8f6fd" media="(prefers-color-scheme: light)" />
    <meta property="og:type" content="website" /><meta property="og:url" content="https://iterm.santi020k.com/" /><meta property="og:site_name" content="Santi020k Theme" /><meta property="og:locale" content="en_US" />
    <meta property="og:title" content="Santi020k iTerm2 Theme" /><meta property="og:description" content="Dark and light terminal presets with calm contrast and a focused violet color language." />
    <meta property="og:image" content="https://iterm.santi020k.com/og-image.png" /><meta property="og:image:width" content="1200" /><meta property="og:image:height" content="630" /><meta property="og:image:alt" content="Santi020k iTerm2 dark terminal preset preview" />
    <meta name="twitter:card" content="summary_large_image" /><meta name="twitter:site" content="@santi020k" /><meta name="twitter:creator" content="@santi020k" /><meta name="twitter:url" content="https://iterm.santi020k.com/" />
    <meta name="twitter:title" content="Santi020k iTerm2 Theme" /><meta name="twitter:description" content="Calm violet dark and light color presets for iTerm2." /><meta name="twitter:image" content="https://iterm.santi020k.com/og-image.png" /><meta name="twitter:image:alt" content="Santi020k iTerm2 theme preview" />
    <Fragment set:html={structuredDataHtml} />
  </head>
  <body>
    <header class="site-header"><div class="shell header-inner">
      <a class="brand" href="#top"><img src="/favicon.svg" width="36" height="36" alt="" /><span>Santi020k <b>iTerm2</b></span></a>
      <nav id="primary-navigation" aria-label="Primary navigation"><a href="#preview">Preview</a><a href="#palette">Palette</a><a href="#install">Install</a><a href="https://theme.santi020k.com/">Theme family</a><a href="https://github.com/santi020k/santi020k-theme">GitHub</a></nav>
      <div class="header-actions"><button class="nav-toggle" aria-controls="primary-navigation" aria-expanded="false" aria-label="Toggle navigation">☰</button><button class="theme-toggle" role="switch" aria-label="Toggle site color theme" aria-checked="true"><span aria-hidden="true">◐</span></button></div>
    </div></header>
    <main id="top">
      <section class="shell hero">
        <div class="hero-copy"><p class="eyebrow">iTerm2 color presets</p><h1>Your terminal, in the same calm violet.</h1><p class="lede">Two complete iTerm2 presets mapped from the Santi020k palette. Deep contrast for late sessions, clear ANSI colors for logs, and a violet cursor that stays easy to find.</p>
          <div class="actions"><a class="button primary" href="/themes/Santi020k%20Dark.itermcolors" download>Download dark</a><a class="button secondary" href="/themes/Santi020k%20Light.itermcolors" download>Download light</a></div>
          <p class="compatibility"><span></span> Free · macOS · iTerm2 3.4+</p>
        </div>
        <div class="terminal-wrap" id="preview"><div class="terminal" data-terminal-theme="dark">
          <div class="terminal-bar"><span class="dots"><i></i><i></i><i></i></span><span>santi020k — zsh — 92×26</span><span></span></div>
          <div class="terminal-body" aria-label="Terminal theme preview"><p><b class="green">➜</b> <b class="cyan">~/Projects/theme</b> <span class="purple">git:(main)</span> <span class="red">✗</span></p><p><span class="muted">$</span> pnpm run validate:iterm</p><p><span class="purple">›</span> Generating Santi020k presets...</p><p><span class="green">✓</span> Dark palette <span class="muted">16 ANSI colors</span></p><p><span class="green">✓</span> Light palette <span class="muted">16 ANSI colors</span></p><p><span class="yellow">!</span> Calm contrast. Durable focus.</p><p>&nbsp;</p><p><b class="green">➜</b> <b class="cyan">~/Projects/theme</b> <span class="cursor">&nbsp;</span></p></div>
          <div class="terminal-switch"><button class="is-active" data-preset="dark" aria-pressed="true">Dark</button><button data-preset="light" aria-pressed="false">Light</button></div>
        </div></div>
      </section>
      <section id="palette" class="shell section"><div class="section-heading"><p class="eyebrow">Full ANSI coverage</p><h2>Readable by role, not loud by default.</h2><p>The base sixteen preserve familiar terminal semantics while pulling every hue into the same muted Santi020k language.</p></div><div class="swatches" aria-label="ANSI palette"><span style="--c:#231d30">00</span><span style="--c:#ea6962">01</span><span style="--c:#7daea3">02</span><span style="--c:#e8b44a">03</span><span style="--c:#9b69f6">04</span><span style="--c:#b48df7">05</span><span style="--c:#89b8c8">06</span><span style="--c:#dfdde3">07</span><span style="--c:#726c7f">08</span><span style="--c:#ff8b84">09</span><span style="--c:#9bc9be">10</span><span style="--c:#f4cb72">11</span><span style="--c:#b48df7">12</span><span style="--c:#d0b5ff">13</span><span style="--c:#a8d6e5">14</span><span style="--c:#fff">15</span></div></section>
      <section id="install" class="install-section"><div class="shell"><div class="section-heading"><p class="eyebrow">Install in a minute</p><h2>Import once. Apply to any profile.</h2></div><ol class="steps"><li><b>Download a preset</b><span>Choose dark or light above. The file stays local.</span></li><li><b>Open iTerm2 settings</b><span>Go to Profiles → Colors → Color Presets…</span></li><li><b>Import and select</b><span>Choose Import…, open the file, then select Santi020k.</span></li></ol><div class="actions centered"><a class="button primary" href="/themes/Santi020k%20Dark.itermcolors" download>Get dark preset</a><a class="button secondary" href="https://github.com/santi020k/santi020k-theme/tree/main/packages/santi020k-iterm-theme">View source</a></div></div></section>
    </main>
    <footer class="shell"><p>Made by <a href="https://santi020k.com">Santiago Molina</a>.</p><div><a href="https://vscode.santi020k.com/">VS Code</a><a href="https://chrome.santi020k.com/">Chrome</a><a href="https://theme.santi020k.com/">All themes</a></div></footer>
    <script>
      import '../main.js'
    </script>
  </body>
</html>
