---
import TerminalPreview from '../components/TerminalPreview.astro'
import SiteLayout from '../layouts/SiteLayout.astro'
const canonical = 'https://terminal.santi020k.com/'
const description = 'One calm violet terminal theme for iTerm2 colors and a Santi020k Powerline prompt for Starship.'
const schema = { '@context': 'https://schema.org', '@type': 'CollectionPage', name: 'Santi020k Terminal Theme', url: canonical, description, hasPart: [{ '@type': 'SoftwareApplication', name: 'Santi020k Zsh setup', url: `${canonical}zsh/` }, { '@type': 'SoftwareApplication', name: 'Santi020k for iTerm2', url: `${canonical}iterm2/` }, { '@type': 'SoftwareApplication', name: 'Santi020k for Starship', url: `${canonical}starship/` }] }
---
<SiteLayout title="Santi020k Terminal Theme — iTerm2 and Starship" {description} {canonical} {schema}>
  <section class="shell hero"><div class="hero-copy"><p class="eyebrow">One terminal theme</p><h1>Color and prompt, finally in sync.</h1><p class="lede">Install the complete Homebrew-managed Zsh setup, or choose only the Santi020k colors and Starship prompt you need.</p><div class="actions"><a class="button primary" href="/zsh/#install">Install complete setup</a><a class="button secondary" href="#components">Browse individual themes</a></div><p class="compatibility"><span></span> macOS · Zsh · Homebrew · free and open source</p></div><TerminalPreview prompt id="preview" /></section>
  <section class="shell section" id="components"><div class="section-heading"><p class="eyebrow">Three coordinated layers</p><h2>Choose what your terminal needs.</h2><p>The Homebrew setup combines the Zsh layer and Starship prompt. The color presets remain separate so you can apply them to the terminal application you use.</p></div><div class="tool-grid tool-grid-three"><a class="tool-card" href="/zsh/"><span class="tool-number">01</span><h3>Complete Zsh setup</h3><p>Install the Santi020k CLI, prompt, completions, suggestions, fuzzy search, and modern command-line tools through Homebrew.</p><b>Install with Homebrew →</b></a><a class="tool-card" href="/iterm2/"><span class="tool-number">02</span><h3>iTerm2 colors</h3><p>Download deep indigo surfaces, readable ANSI roles, selection colors, and a violet cursor.</p><b>Open iTerm2 guide →</b></a><a class="tool-card" href="/starship/"><span class="tool-number">03</span><h3>Starship prompt</h3><p>Install the complete setup or add only the focused Powerline prompt to your existing shell.</p><b>Choose an install path →</b></a></div></section>
  <section class="install-section"><div class="shell split-callout"><div><p class="eyebrow">More terminals</p><h2>One palette for every shell.</h2></div><div><p>Generated dark and light presets are ready for Ghostty, WezTerm, Kitty, Windows Terminal, and Alacritty.</p><a class="button primary" href="/ports/">Download terminal presets</a></div></div></section>
</SiteLayout>
