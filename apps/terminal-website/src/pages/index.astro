---
import TerminalPreview from '../components/TerminalPreview.astro'
import SiteLayout from '../layouts/SiteLayout.astro'
const canonical = 'https://terminal.santi020k.com/'
const description = 'One calm violet terminal theme for iTerm2 colors and a Santi020k Powerline prompt for Starship.'
const schema = { '@context': 'https://schema.org', '@type': 'CollectionPage', name: 'Santi020k Terminal Theme', url: canonical, description, hasPart: [{ '@type': 'SoftwareApplication', name: 'Santi020k for iTerm2', url: `${canonical}iterm2/` }, { '@type': 'SoftwareApplication', name: 'Santi020k for Starship', url: `${canonical}starship/` }] }
---
<SiteLayout title="Santi020k Terminal Theme — iTerm2 and Starship" {description} {canonical} {schema}>
  <section class="shell hero"><div class="hero-copy"><p class="eyebrow">One terminal theme</p><h1>Color and prompt, finally in sync.</h1><p class="lede">Bring the Santi020k violet language to the whole terminal. Start with matching iTerm2 colors, add the Starship Powerline prompt, or install either one on its own.</p><div class="actions"><a class="button primary" href="/starship/">Install Starship prompt</a><a class="button secondary" href="/iterm2/">Get iTerm2 colors</a></div><p class="compatibility"><span></span> Free · open source · dark and light</p></div><TerminalPreview prompt id="preview" /></section>
  <section class="shell section"><div class="section-heading"><p class="eyebrow">Two coordinated layers</p><h2>Choose what your terminal needs.</h2><p>The color scheme controls the terminal canvas and ANSI output. Starship controls the prompt around every command.</p></div><div class="tool-grid"><a class="tool-card" href="/iterm2/"><span class="tool-number">01</span><h3>iTerm2 colors</h3><p>Deep indigo surfaces, readable ANSI roles, selection colors, and a violet cursor.</p><b>Open iTerm2 guide →</b></a><a class="tool-card" href="/starship/"><span class="tool-number">02</span><h3>Starship prompt</h3><p>A focused Powerline prompt with directory, Git state, runtimes, duration, and time.</p><b>Open Starship guide →</b></a></div></section>
  <section class="install-section"><div class="shell split-callout"><div><p class="eyebrow">Designed to grow</p><h2>One home for every terminal.</h2></div><p>Future Ghostty, WezTerm, Kitty, and Windows Terminal presets can join the same project without creating another product site.</p></div></section>
</SiteLayout>
