---
import TerminalPreview from '../components/TerminalPreview.astro'
import SiteLayout from '../layouts/SiteLayout.astro'
const canonical = 'https://terminal.santi020k.com/iterm2/'
const description = 'Download Santi020k dark and light iTerm2 color presets with complete ANSI coverage and calm violet contrast.'
const schema = { '@context': 'https://schema.org', '@type': 'SoftwareApplication', name: 'Santi020k Theme for iTerm2', applicationCategory: 'DeveloperApplication', applicationSubCategory: 'Terminal Color Scheme', operatingSystem: 'macOS', offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' }, url: canonical, downloadUrl: 'https://terminal.santi020k.com/themes/Santi020k%20Dark.itermcolors', description }
---
<SiteLayout title="Santi020k iTerm2 Theme — Dark and Light Presets" {description} {canonical} {schema} image="og-iterm2.png" imageAlt="Santi020k dark and light iTerm2 color presets">
  <section class="shell hero"><div class="hero-copy"><p class="eyebrow">iTerm2 color presets</p><h1>The canvas for a calmer terminal.</h1><p class="lede">Complete dark and light profiles mapped from the Santi020k palette, including ANSI output, selection, links, and the focused violet cursor.</p><div class="actions"><a class="button primary" href="/themes/Santi020k%20Dark.itermcolors" download>Download dark</a><a class="button secondary" href="/themes/Santi020k%20Light.itermcolors" download>Download light</a></div><p class="compatibility"><span></span> macOS · iTerm2 3.4+ · no account</p></div><TerminalPreview id="preview" /></section>
  <section class="shell section"><div class="section-heading"><p class="eyebrow">Full ANSI coverage</p><h2>Readable by role, not loud by default.</h2><p>The base sixteen preserve familiar terminal semantics while pulling every hue into the same muted Santi020k language.</p></div><div class="swatches" aria-label="ANSI palette"><span style="--c:#231d30">00</span><span style="--c:#ea6962">01</span><span style="--c:#7daea3">02</span><span style="--c:#e8b44a">03</span><span style="--c:#9b69f6">04</span><span style="--c:#b48df7">05</span><span style="--c:#89b8c8">06</span><span style="--c:#dfdde3">07</span><span style="--c:#726c7f">08</span><span style="--c:#ff8b84">09</span><span style="--c:#9bc9be">10</span><span style="--c:#f4cb72">11</span><span style="--c:#b48df7">12</span><span style="--c:#d0b5ff">13</span><span style="--c:#a8d6e5">14</span><span style="--c:#fff">15</span></div></section>
  <section class="install-section"><div class="shell"><div class="section-heading"><p class="eyebrow">Install in a minute</p><h2>Import once. Apply to any profile.</h2></div><ol class="steps"><li><b>Download a preset</b><span>Choose dark or light. The preset stays local.</span></li><li><b>Open iTerm2 settings</b><span>Go to Profiles → Colors → Color Presets…</span></li><li><b>Import and select</b><span>Choose Import…, open the file, then select Santi020k.</span></li></ol><div class="actions centered"><a class="button primary" href="/themes/Santi020k%20Dark.itermcolors" download>Get dark preset</a><a class="button secondary" href="/starship/">Add the matching prompt</a></div></div></section>
  <section class="shell section"><div class="section-heading"><p class="eyebrow">Transparent windows</p><h2>Keep the canvas translucent and the prompt solid.</h2><p>iTerm2 can apply window transparency to colored text backgrounds too. That makes Starship’s segment fills fade while its Powerline separators stay solid.</p></div><aside class="notice"><b>Enable opaque prompt segments</b><p>Open Settings → Profiles → Window, enable <strong>Keep background colors opaque</strong>, then set Background Transparency to the amount you prefer. The terminal canvas remains transparent while Starship’s directory, Git, runtime, and time segments keep their intended contrast.</p></aside></section>
</SiteLayout>
