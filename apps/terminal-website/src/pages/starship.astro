---
import TerminalPreview from '../components/TerminalPreview.astro'
import SiteLayout from '../layouts/SiteLayout.astro'
import { promptVariants, starshipFilename } from '../../../../packages/santi020k-terminal-theme/prompt-presets.mjs'
// cspell:ignore mktemp
const canonical = 'https://terminal.santi020k.com/starship/'
const description = 'Install the Santi020k Powerline prompt for Starship with coordinated dark and light violet palettes.'
const downloadBase = 'https://terminal.santi020k.com/starship'
const schema = { '@context': 'https://schema.org', '@type': 'SoftwareApplication', name: 'Santi020k Theme for Starship', applicationCategory: 'DeveloperApplication', operatingSystem: 'macOS, Linux, Windows', offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' }, url: canonical, downloadUrl: `${downloadBase}/santi020k-dark.toml`, description }
const commands = {
  install: 'brew install starship',
  init: 'eval "$(starship init zsh)"',
  backup: 'test ! -f ~/.config/starship.toml || cp ~/.config/starship.toml ~/.config/starship.toml.backup',
  dark: `mkdir -p ~/.config && curl -fsSL ${downloadBase}/santi020k-dark.toml -o ~/.config/starship.toml`,
  light: `mkdir -p ~/.config && curl -fsSL ${downloadBase}/santi020k-light.toml -o ~/.config/starship.toml`,
  persist: `grep -qxF 'eval "$(starship init zsh)"' ~/.zshrc || echo 'eval "$(starship init zsh)"' >> ~/.zshrc`,
  restart: 'exec zsh',
  font: 'brew install --cask font-caskaydia-cove-nerd-font',
  openIterm: 'open -a iTerm',
  autoDownload: `mkdir -p ~/.config/starship && curl -fsSL ${downloadBase}/santi020k-dark.toml -o ~/.config/starship/santi020k-dark.toml && curl -fsSL ${downloadBase}/santi020k-light.toml -o ~/.config/starship/santi020k-light.toml`,
  autoInstall: `tmp_file="$(mktemp)" && curl -fsSL https://terminal.santi020k.com/zsh/santi020k-auto-theme.zsh -o "$tmp_file" && grep -q '^# Select the Santi020k Starship preset' "$tmp_file" && zsh -n "$tmp_file" && mv "$tmp_file" ~/.config/starship/santi020k-auto-theme.zsh && { grep -qxF 'source "$HOME/.config/starship/santi020k-auto-theme.zsh"' ~/.zshrc || echo 'source "$HOME/.config/starship/santi020k-auto-theme.zsh"' >> ~/.zshrc; } && exec zsh || { rm -f "$tmp_file"; echo 'Automatic theme download failed; the existing configuration was not replaced.' >&2; }`,
}
const variants = Object.entries(promptVariants).map(([key, variant]) => ({ key, ...variant, dark: `/starship/${starshipFilename('dark', key)}`, light: `/starship/${starshipFilename('light', key)}` }))
---
<SiteLayout title="Santi020k Starship Theme — Powerline Prompt" {description} {canonical} {schema} imageAlt="Santi020k Powerline prompt for Starship">
  <section class="shell hero"><div class="hero-copy"><p class="eyebrow">Starship prompt preset</p><h1>Powerline shape. Santi020k focus.</h1><p class="lede">Inspired by Starship’s Pastel Powerline preset, rebuilt with a quieter violet progression and clear semantic roles for directory, Git, runtimes, and command state.</p><div class="actions"><a class="button primary" href="#install">Install the prompt</a><a class="button secondary" href="/starship/santi020k-dark.toml" download>Download TOML</a></div><p class="compatibility"><span></span> Zsh, Bash, Fish, PowerShell · Nerd Font required</p></div><TerminalPreview prompt id="preview" /></section>
  <section class="shell section compact-section"><div class="section-heading"><p class="eyebrow">Built for daily work</p><h2>Information where it earns its space.</h2></div><div class="feature-grid"><div><b>Directory first</b><p>Your current context gets the strongest violet.</p></div><div><b>Git at a glance</b><p>Branch and working state stay grouped together.</p></div><div><b>Runtimes on demand</b><p>Language versions appear only when relevant.</p></div><div><b>Quiet history</b><p>Time and duration recede into the final segment.</p></div></div></section>
  <section class="install-section"><div class="shell"><div class="section-heading"><p class="eyebrow">Choose your density</p><h2>Three prompts, one palette.</h2><p>The original download remains the rich preset. Portable replaces application icons with labels; Minimal removes runtime modules for a quieter prompt.</p></div><div class="preset-grid">{variants.map(variant => <article><h3>{variant.name}</h3><p>{variant.description}</p><div class="actions"><a class="button secondary" href={variant.dark} download>Dark</a><a class="button secondary" href={variant.light} download>Light</a></div></article>)}</div></div></section>
  <section class="install-section" id="install"><div class="shell"><div class="section-heading"><p class="eyebrow">Safe manual install</p><h2>Four small steps. Nothing hidden.</h2><p>Run each command separately so you can see exactly what changes. A successful preset download is silent.</p></div><ol class="install-list">
    <li><div><b>Install Starship</b><span>Skip this if Starship is already installed.</span></div><div class="command"><code>{commands.install}</code><button data-copy={commands.install} aria-label="Copy Starship install command">Copy</button></div></li>
    <li><div><b>Enable it in the current shell</b><span>This lets you try Starship immediately.</span></div><div class="command"><code>{commands.init}</code><button data-copy={commands.init} aria-label="Copy Zsh initialization">Copy</button></div></li>
    <li><div><b>Back up your current preset</b><span>This only creates a backup when a config already exists.</span></div><div class="command"><code>{commands.backup}</code><button data-copy={commands.backup} aria-label="Copy backup command">Copy</button></div></li>
    <li><div><b>Choose dark or light</b><span>The folder is created if needed, then the preset becomes your Starship configuration.</span></div><div class="variant-commands"><div class="command"><code>{commands.dark}</code><button data-copy={commands.dark} aria-label="Copy dark preset command">Copy dark</button></div><div class="command"><code>{commands.light}</code><button data-copy={commands.light} aria-label="Copy light preset command">Copy light</button></div></div></li>
  </ol><aside class="notice"><b>Using Oh My Zsh?</b><p>Set <code>ZSH_THEME=""</code> before Oh My Zsh loads. Your plugins can stay enabled while Starship owns the prompt.</p></aside></div></section>
  <section class="shell section"><div class="section-heading"><p class="eyebrow">Activate the theme</p><h2>Keep Starship enabled after closing Terminal.</h2><p>The first command adds Starship to <code>~/.zshrc</code> only when it is not already there. The second starts a fresh Zsh session so the Santi020k prompt appears.</p></div><div class="simple-command-grid"><div><span>Save to Zsh</span><div class="command"><code>{commands.persist}</code><button data-copy={commands.persist} aria-label="Copy persistent Zsh setup">Copy</button></div></div><div><span>Restart Zsh</span><div class="command"><code>{commands.restart}</code><button data-copy={commands.restart} aria-label="Copy Zsh restart command">Copy</button></div></div></div></section>
  <section class="install-section"><div class="shell"><div class="section-heading"><p class="eyebrow">Automatic appearance</p><h2>Follow macOS light and dark mode.</h2><p>This optional Zsh setup keeps both presets and selects one through <code>STARSHIP_CONFIG</code>. It checks the macOS appearance before every prompt, so an open shell follows later system changes.</p></div><ol class="install-list">
    <li><div><b>Download both presets</b><span>They live beside your default Starship configuration and do not overwrite it.</span></div><div class="command"><code>{commands.autoDownload}</code><button data-copy={commands.autoDownload} aria-label="Copy both Starship presets download command">Copy</button></div></li>
    <li><div><b>Enable automatic detection</b><span>Install the small Zsh helper, source it from <code>~/.zshrc</code>, and restart Zsh.</span></div><div class="command command-multiline"><code>{commands.autoInstall}</code><button data-copy={commands.autoInstall} aria-label="Copy automatic appearance setup commands">Copy</button></div></li>
  </ol><aside class="notice"><b>macOS and Zsh only</b><p>Detection follows the macOS system appearance, not the background color of an independently configured iTerm2 profile. Keep the manual dark or light preset if your terminal appearance intentionally differs from macOS.</p></aside></div></section>
  <section class="shell section"><div class="section-heading"><p class="eyebrow">Match the preview</p><h2>Give the prompt room to breathe.</h2><p>The preset supplies the labels, spacing, and colors shown above. iTerm2 controls their physical size, so typography is the final part of the setup.</p></div><div class="font-command-grid"><div><span>1. Install with Homebrew</span><div class="command"><code>{commands.font}</code><button data-copy={commands.font} aria-label="Copy Nerd Font install command">Copy</button></div></div><div><span>2. Open iTerm2</span><div class="command"><code>{commands.openIterm}</code><button data-copy={commands.openIterm} aria-label="Copy command to open iTerm2">Copy</button></div></div><div class="font-result"><b>3. Match the type scale</b><p>Press <kbd>⌘</kbd><kbd>,</kbd>, then open Profiles → Text. Choose CaskaydiaCove Nerd Font at <strong>15 pt</strong> and set vertical spacing to about <strong>110%</strong>. Open a new terminal window afterward.</p></div></div><div class="actions"><a class="button secondary" href="https://www.nerdfonts.com/font-downloads">Other Nerd Fonts</a><a class="button secondary" href="/iterm2/">Install matching colors</a></div></section>
</SiteLayout>
