---
import SiteLayout from '../layouts/SiteLayout.astro'

const formats = [
  ['Ghostty', 'ghostty', 'santi020k-{mode}'],
  ['Kitty', 'kitty', 'santi020k-{mode}.conf'],
  ['WezTerm', 'wezterm', 'santi020k-{mode}.lua'],
  ['Windows Terminal', 'windows-terminal', 'santi020k-{mode}.json'],
  ['Alacritty', 'alacritty', 'santi020k-{mode}.toml'],
]
const schema = { '@context': 'https://schema.org', '@type': 'SoftwareApplication', name: 'Santi020k terminal color presets', applicationCategory: 'DeveloperApplication' }
---
<SiteLayout title="Terminal color presets — Santi020k Theme" description="Matching dark and light color presets for Ghostty, Kitty, WezTerm, Windows Terminal, and Alacritty." canonical="https://terminal.santi020k.com/ports/" schema={schema} image="og-ports.png" imageAlt="Santi020k dark and light color presets for five terminal applications">
  <section class="shell section compact-section"><div class="section-heading"><p class="eyebrow">Terminal ports</p><h1>One palette, five more terminals.</h1><p>Download a generated dark or light preset. Every file comes from the same canonical ANSI palette as the VS Code and iTerm2 themes.</p></div>
    <div class="preset-grid">
      {formats.map(([name, directory, filename]) => <article><h2>{name}</h2><p>Native configuration for {name}, generated from the shared Santi020k palette.</p><div class="actions"><a class="button primary" href={`/ports/${directory}/${filename.replace('{mode}', 'dark')}`} download>Dark</a><a class="button secondary" href={`/ports/${directory}/${filename.replace('{mode}', 'light')}`} download>Light</a></div></article>)}
    </div>
  </section>
</SiteLayout>
