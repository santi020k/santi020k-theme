---
import { promptSegments } from '../../../../packages/santi020k-terminal-theme/prompt-presets.mjs'
const { prompt = false, id } = Astro.props
const segment = Object.fromEntries(promptSegments.map(item => [item.key, item.preview]))
---
<div class="terminal-wrap" id={id}><div class="terminal" data-terminal-theme="dark">
  <div class="terminal-bar"><span class="dots"><i></i><i></i><i></i></span><span>santi020k — zsh — 92×26</span><span></span></div>
  <div class:list={["terminal-body", { "powerline-preview": prompt }]} aria-label="Terminal theme preview">
    {prompt ? <>
      <p class="powerline"><span class="cap start" aria-hidden="true"></span><span class="segment os">{segment.os}</span><span class="join os-dir" aria-hidden="true"></span><span class="segment dir">{segment.directory}</span><span class="join dir-git" aria-hidden="true"></span><span class="segment git">{segment.git} +2</span><span class="join git-runtime" aria-hidden="true"></span><span class="segment runtime">{segment.runtime}</span><span class="join runtime-time" aria-hidden="true"></span><span class="segment time">{segment.time}</span><span class="cap end" aria-hidden="true"></span></p>
      <p><b class="purple">❯</b> pnpm run focus</p><p class="muted">Calm contrast. Durable focus.</p><p>&nbsp;</p>
      <p class="powerline"><span class="cap start" aria-hidden="true"></span><span class="segment os">{segment.os}</span><span class="join os-dir" aria-hidden="true"></span><span class="segment dir">{segment.directory}</span><span class="join dir-git" aria-hidden="true"></span><span class="segment git">{segment.git}</span><span class="join git-runtime" aria-hidden="true"></span><span class="segment runtime">{segment.runtime}</span><span class="join runtime-time" aria-hidden="true"></span><span class="segment time">14:33</span><span class="cap end" aria-hidden="true"></span></p><p><b class="purple">❯</b> <span class="cursor">&nbsp;</span></p>
    </> : <>
      <p><b class="green">➜</b> <b class="cyan">~/Projects/theme</b> <span class="purple">git:(main)</span> <span class="red">✗</span></p><p><span class="muted">$</span> pnpm run validate:terminal</p><p><span class="purple">›</span> Generating Santi020k presets...</p><p><span class="green">✓</span> Dark palette <span class="muted">16 ANSI colors</span></p><p><span class="green">✓</span> Light palette <span class="muted">16 ANSI colors</span></p><p><span class="yellow">!</span> Calm contrast. Durable focus.</p><p>&nbsp;</p><p><b class="green">➜</b> <b class="cyan">~/Projects/theme</b> <span class="cursor">&nbsp;</span></p>
    </>}
  </div>
  <div class="terminal-switch"><button class="is-active" data-preset="dark" aria-pressed="true">Dark</button><button data-preset="light" aria-pressed="false">Light</button></div>
</div></div>
