  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#6020b8",
    "class": "#5a18a8",
    "interface": "#6020b8",
    "enum": "#5a18a8",
    "type": "#6020b8",
    "typeParameter": "#403860",
    "function": "#5a18a8",
    "method": "#5a18a8",
    "macro": "#7030b0",
    "variable": "#302e36",
    "parameter": "#403860",
    "property": "#6020b8",
    "enumMember": "#8030c8",
    "event": "#7030b0",
    "operator": "#8b52d6",
    "keyword": { "foreground": "#5a1ab0", "italic": true },
    "comment": { "foreground": "#9880c0", "italic": true },
    "string": "#7030b0",
    "number": "#8030c8",
    "regexp": "#8030c8",
    "decorator": "#5a18a8",
    "*.declaration": { "bold": true },
    "*.readonly": { "italic": true },
    "*.deprecated": { "strikethrough": true }
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#9880c0", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.backtick",
        "string.template"
      ],
      "settings": { "foreground": "#7030b0" }
    },
    {
      "name": "Template expression punctuation",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end"
      ],
      "settings": { "foreground": "#8b52d6" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#8030c8" }
    },
    {
      "name": "Boolean & null",
      "scope": ["constant.language"],
      "settings": { "foreground": "#6319be", "fontStyle": "italic" }
    },
    {
      "name": "Other constants",
      "scope": ["constant.character", "constant.other"],
      "settings": { "foreground": "#8030c8" }
    },
    {
      "name": "Keywords",
      "scope": ["keyword.control", "keyword.other"],
      "settings": { "foreground": "#5a1ab0", "fontStyle": "italic" }
    },
    {
      "name": "Storage (const, let, var, function, class)",
      "scope": ["storage.type", "storage.modifier"],
      "settings": { "foreground": "#5a1ab0", "fontStyle": "italic" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#8b52d6" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation"],
      "settings": { "foreground": "#9880c0" }
    },
    {
      "name": "Function names",
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#6020b8" }
    },
    {
      "name": "Function parameters",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#403860", "fontStyle": "italic" }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "support.class",
        "support.type",
        "support.type.primitive"
      ],
      "settings": { "foreground": "#5a18a8" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other.readwrite"],
      "settings": { "foreground": "#302e36" }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property"
      ],
      "settings": { "foreground": "#403860" }
    },
    {
      "name": "HTML / JSX tags",
      "scope": ["entity.name.tag", "support.class.component"],
      "settings": { "foreground": "#5a1ab0" }
    },
    {
      "name": "HTML / JSX attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#6020b8" }
    },
    {
      "name": "CSS property names",
      "scope": ["support.type.property-name", "support.type.property-name.css"],
      "settings": { "foreground": "#6020b8" }
    },
    {
      "name": "CSS property values",
      "scope": ["support.constant.property-value"],
      "settings": { "foreground": "#7030b0" }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css"
      ],
      "settings": { "foreground": "#5a18a8" }
    },
    {
      "name": "JSON keys",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#6020b8" }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp"],
      "settings": { "foreground": "#8030c8" }
    },
    {
      "name": "Decorators",
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": { "foreground": "#8b52d6", "fontStyle": "italic" }
    },
    {
      "name": "Escape sequences",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#6319be" }
    },
    {
      "name": "Markdown headings",
      "scope": ["markup.heading", "punctuation.definition.heading.markdown"],
      "settings": { "foreground": "#5a18a8", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#302e36", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#403860", "fontStyle": "italic" }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#5a1ab0" }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.raw.inline", "markup.fenced_code.block"],
      "settings": { "foreground": "#7030b0" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": { "foreground": "#c0392b" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#c07a10", "fontStyle": "strikethrough" }
    },
    {
      "name": "Language variables (this, self, super)",
      "scope": ["variable.language"],
      "settings": { "foreground": "#6319be", "fontStyle": "italic" }
    },
    {
      "name": "Import / export keywords",
      "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from"],
      "settings": { "foreground": "#5a1ab0", "fontStyle": "italic" }
    },
    {
      "name": "Markdown blockquote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#9880c0", "fontStyle": "italic" }
    },
    {
      "name": "Markdown list markers",
      "scope": ["markup.list", "punctuation.definition.list.begin.markdown"],
      "settings": { "foreground": "#8b52d6" }
    }
  ]
}
