  "semanticHighlighting": true,
  "semanticTokenColors": {
    "*.abstract": {
      "italic": true
    },
    "*.async": {
      "foreground": "#0870a0"
    },
    "*.declaration": {
      "bold": true
    },
    "*.defaultLibrary": {
      "foreground": "#4a1a98"
    },
    "*.deprecated": {
      "strikethrough": true
    },
    "*.mutable": {
      "underline": true
    },
    "*.readonly": {
      "italic": true
    },
    "*.static": {
      "bold": true
    },
    "class": "#5a18a8",
    "comment": {
      "foreground": "#9880c0",
      "italic": true
    },
    "decorator": "#5a18a8",
    "enum": "#5a18a8",
    "enumMember": "#8030c8",
    "event": "#7030b0",
    "function": "#5a18a8",
    "interface": "#6020b8",
    "keyword": {
      "foreground": "#5a1ab0",
      "italic": true
    },
    "macro": "#7030b0",
    "method": "#5a18a8",
    "namespace": "#6020b8",
    "number": "#8030c8",
    "operator": "#8b52d6",
    "parameter": "#403860",
    "property": "#6020b8",
    "regexp": "#8030c8",
    "string": "#7030b0",
    "type": "#6020b8",
    "typeParameter": "#403860",
    "variable": "#302e36"
  },
