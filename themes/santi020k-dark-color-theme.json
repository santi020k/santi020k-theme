  "semanticHighlighting": true,
  "semanticTokenColors": {
    "*.abstract": {
      "italic": true
    },
    "*.async": {
      "foreground": "#89b8c8"
    },
    "*.declaration": {
      "bold": true
    },
    "*.defaultLibrary": {
      "foreground": "#a0c8e0"
    },
    "*.deprecated": {
      "strikethrough": true
    },
    "*.mutable": {
      "underline": true
    },
    "*.readonly": {
      "italic": true
    },
    "*.static": {
      "bold": true
    },
    "class": "#945df4",
    "comment": {
      "foreground": "#71569f",
      "italic": true
    },
    "decorator": "#945df4",
    "enum": "#945df4",
    "enumMember": "#c3a4f9",
    "event": "#b48df7",
    "function": "#945df4",
    "interface": "#a475f5",
    "keyword": {
      "foreground": "#9b69f6",
      "italic": true
    },
    "macro": "#b48df7",
    "method": "#945df4",
    "namespace": "#a475f5",
    "number": "#c3a4f9",
    "operator": "#8d6fd1",
    "parameter": "#dbd4e8",
    "property": "#a475f5",
    "regexp": "#c3a4f9",
    "string": "#b48df7",
    "type": "#a475f5",
    "typeParameter": "#dbd4e8",
    "variable": "#dfdde3"
  },
  "tokenColors": [
    {
