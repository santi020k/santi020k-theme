  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#584878", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.backtick",
        "string.template"
      ],
      "settings": { "foreground": "#d4a8ff" }
    },
    {
      "name": "Template expression punctuation",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end"
      ],
      "settings": { "foreground": "#9070c0" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#e8b4ff" }
    },
    {
      "name": "Boolean & null",
      "scope": ["constant.language"],
      "settings": { "foreground": "#c090ff", "fontStyle": "italic" }
    },
    {
      "name": "Other constants",
      "scope": ["constant.character", "constant.other"],
      "settings": { "foreground": "#e8b4ff" }
    },
    {
      "name": "Keywords",
      "scope": ["keyword.control", "keyword.other"],
      "settings": { "foreground": "#a06ee6", "fontStyle": "italic" }
    },
    {
      "name": "Storage (const, let, var, function, class)",
      "scope": ["storage.type", "storage.modifier"],
      "settings": { "foreground": "#a06ee6", "fontStyle": "italic" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#9070c0" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation"],
      "settings": { "foreground": "#7868a0" }
    },
    {
      "name": "Function names",
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#b890f0" }
    },
    {
      "name": "Function parameters",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#d8c8f0", "fontStyle": "italic" }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "support.class",
        "support.type",
        "support.type.primitive"
      ],
      "settings": { "foreground": "#c090ff" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other.readwrite"],
      "settings": { "foreground": "#e8e0f0" }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property"
      ],
      "settings": { "foreground": "#d8c8f0" }
    },
    {
      "name": "HTML / JSX tags",
      "scope": ["entity.name.tag", "support.class.component"],
      "settings": { "foreground": "#a06ee6" }
    },
    {
      "name": "HTML / JSX attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#b890f0" }
    },
    {
      "name": "CSS property names",
      "scope": ["support.type.property-name", "support.type.property-name.css"],
      "settings": { "foreground": "#b890f0" }
    },
    {
      "name": "CSS property values",
      "scope": ["support.constant.property-value"],
      "settings": { "foreground": "#d4a8ff" }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css"
      ],
      "settings": { "foreground": "#c090ff" }
    },
    {
      "name": "JSON keys",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#b890f0" }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp"],
      "settings": { "foreground": "#e8b4ff" }
    },
    {
      "name": "Decorators",
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": { "foreground": "#9070c0", "fontStyle": "italic" }
    },
    {
      "name": "Escape sequences",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#c090ff" }
    },
    {
      "name": "Markdown headings",
      "scope": ["markup.heading", "punctuation.definition.heading.markdown"],
      "settings": { "foreground": "#c090ff", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#e8e0f0", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#d8c8f0", "fontStyle": "italic" }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#a06ee6" }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.raw.inline", "markup.fenced_code.block"],
      "settings": { "foreground": "#d4a8ff" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": { "foreground": "#ea6962" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#e8b44a", "fontStyle": "strikethrough" }
    }
  ]
}
