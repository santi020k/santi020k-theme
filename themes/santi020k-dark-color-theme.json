  "semanticHighlighting": true,
  "semanticTokenColors": {
    "*.abstract": {
      "italic": true
    },
    "*.async": {
      "foreground": "#89b8c8"
    },
    "*.declaration": {
      "bold": true
    },
    "*.defaultLibrary": {
      "foreground": "#a0c8e0"
    },
    "*.deprecated": {
      "strikethrough": true
    },
    "*.readonly": {
      "italic": true
    },
    "*.static": {
      "bold": true
    },
    "class": "#c090ff",
    "comment": {
      "foreground": "#7060a8",
      "italic": true
    },
    "decorator": "#c090ff",
    "enum": "#c090ff",
    "enumMember": "#e8b4ff",
    "event": "#d4a8ff",
    "function": "#c090ff",
    "interface": "#b890f0",
    "keyword": {
      "foreground": "#a06ee6",
      "italic": true
    },
    "macro": "#d4a8ff",
    "method": "#c090ff",
    "namespace": "#b890f0",
    "number": "#e8b4ff",
    "operator": "#9070c0",
    "parameter": "#d8c8f0",
    "property": "#b890f0",
    "regexp": "#e8b4ff",
    "string": "#d4a8ff",
    "type": "#b890f0",
    "typeParameter": "#d8c8f0",
    "variable": "#e8e0f0"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7060a8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.backtick",
        "string.template"
      ],
      "settings": {
        "foreground": "#d4a8ff"
      }
    },
    {
      "name": "Template expression punctuation",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end"
      ],
      "settings": {
        "foreground": "#9070c0"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#e8b4ff"
      }
    },
    {
      "name": "Boolean & null",
      "scope": [
        "constant.language"
      ],
      "settings": {
        "foreground": "#c090ff",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Other constants",
      "scope": [
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#e8b4ff"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword.control",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#a06ee6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Storage (const, let, var, function, class)",
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#a06ee6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#9070c0"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#7868a0"
      }
    },
    {
      "name": "Function names",
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#b890f0"
      }
    },
    {
      "name": "Function parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#d8c8f0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "support.class",
        "support.type",
        "support.type.primitive"
      ],
      "settings": {
        "foreground": "#c090ff"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#e8e0f0"
      }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#d8c8f0"
      }
    },
    {
      "name": "HTML / JSX tags",
      "scope": [
        "entity.name.tag",
        "support.class.component"
