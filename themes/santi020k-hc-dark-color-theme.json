      ],
      "settings": {
        "foreground": "#60c8e0"
      }
    },
    {
      "name": "JSON numbers",
      "scope": [
        "constant.numeric.json"
      ],
      "settings": {
        "foreground": "#ffc060"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#f0b0ff"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#a070d0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Escape sequences",
      "scope": [
        "constant.character.escape"
