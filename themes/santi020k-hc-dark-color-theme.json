      "scope": [
        "markup.strikethrough"
      ],
      "settings": {
        "foreground": "#a070d0",
        "fontStyle": "strikethrough"
      }
    },
    {
      "name": "Constants (non-semantic fallback)",
      "scope": [
        "variable.other.constant",
        "variable.other.constant.object"
      ],
      "settings": {
        "foreground": "#f0b0ff",
        "fontStyle": "italic"
      }
    },
    {
      "name": "TOML / INI section headers",
      "scope": [
        "entity.name.section.group-title.ini",
