  "semanticHighlighting": true,
  "semanticTokenColors": {
    "*.abstract": {
      "italic": true
    },
    "*.async": {
      "foreground": "#60c8e0"
    },
    "*.declaration": {
      "bold": true
    },
    "*.defaultLibrary": {
      "foreground": "#80d8f0"
    },
    "*.deprecated": {
      "strikethrough": true
    },
    "*.readonly": {
      "italic": true
    },
    "*.static": {
      "bold": true
    },
    "class": "#c080ff",
    "comment": {
      "foreground": "#8868c8",
      "italic": true
    },
    "decorator": "#c080ff",
    "enum": "#c080ff",
    "enumMember": "#f0b0ff",
    "event": "#e0a0ff",
    "function": "#c080ff",
    "interface": "#b870f8",
    "keyword": {
      "foreground": "#a860f0",
      "italic": true
    },
    "macro": "#e0a0ff",
    "method": "#c080ff",
    "namespace": "#b870f8",
    "number": "#f0b0ff",
    "operator": "#a070d0",
    "parameter": "#dcc8fc",
    "property": "#b870f8",
    "regexp": "#f0b0ff",
    "string": "#e0a0ff",
    "type": "#b870f8",
    "typeParameter": "#dcc8fc",
    "variable": "#f0e8ff"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8868c8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.backtick",
        "string.template"
      ],
      "settings": {
        "foreground": "#e0a0ff"
      }
    },
    {
      "name": "Template expression punctuation",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end"
      ],
      "settings": {
        "foreground": "#a070d0"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#f0b0ff"
      }
    },
    {
      "name": "Boolean & null",
      "scope": [
        "constant.language"
      ],
      "settings": {
        "foreground": "#c080ff",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Other constants",
      "scope": [
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#f0b0ff"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword.control",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#a860f0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Storage (const, let, var, function, class)",
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#a860f0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#a070d0"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#9070c8"
      }
    },
    {
      "name": "Function names",
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#b870f8"
      }
    },
    {
      "name": "Function parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#dcc8fc",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "support.class",
        "support.type",
        "support.type.primitive"
      ],
      "settings": {
        "foreground": "#c080ff"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#f0e8ff"
      }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#dcc8fc"
      }
    },
    {
      "name": "HTML / JSX tags",
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#a860f0"
      }
    },
    {
      "name": "HTML / JSX attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#b870f8"
      }
    },
    {
      "name": "CSS property names",
      "scope": [
        "support.type.property-name",
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#b870f8"
      }
    },
    {
      "name": "CSS property values",
      "scope": [
        "support.constant.property-value"
      ],
      "settings": {
        "foreground": "#e0a0ff"
      }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css"
      ],
      "settings": {
        "foreground": "#c080ff"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#b870f8"
      }
    },
    {
      "name": "JSON string values",
      "scope": [
