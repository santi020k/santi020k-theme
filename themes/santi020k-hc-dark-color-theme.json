    {
      "name": "Import / export keywords",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#a860f0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown blockquote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#9070c8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown list markers",
      "scope": [
        "markup.list",
        "punctuation.definition.list.begin.markdown"
