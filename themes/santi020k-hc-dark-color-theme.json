  "semanticHighlighting": true,
  "semanticTokenColors": {
    "*.abstract": {
      "italic": true
    },
    "*.async": {
      "foreground": "#60c8e0"
    },
    "*.declaration": {
      "bold": true
    },
    "*.defaultLibrary": {
      "foreground": "#80d8f0"
    },
    "*.deprecated": {
      "strikethrough": true
    },
    "*.mutable": {
      "underline": true
    },
    "*.readonly": {
      "foreground": "#f0ebfacc",
      "italic": true
    },
    "*.static": {
      "bold": true
    },
    "class": "#a570ff",
    "comment": {
      "foreground": "#8264b4",
      "italic": true
    },
    "decorator": "#a570ff",
    "enum": "#a570ff",
    "enumMember": "#dbc7ff",
    "event": "#c5a3ff",
    "function": "#a570ff",
    "interface": "#a677f8",
    "keyword": {
      "foreground": "#955ff2",
      "italic": true
    },
    "macro": "#c5a3ff",
    "method": "#a570ff",
    "namespace": "#a677f8",
    "number": "#dbc7ff",
    "operator": "#987acd",
    "parameter": "#decff7",
    "property": "#a677f8",
    "regexp": "#dbc7ff",
    "string": "#c5a3ff",
    "type": "#a677f8",
    "typeParameter": "#decff7",
    "variable": "#f0ebfa"
  },
