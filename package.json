{
  "name": "@santi020k/santi020k-theme-root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm run site:dev",
    "build": "turbo run build",
    "build:themes": "pnpm --filter santi020k-theme run build",
    "validate": "pnpm run build && pnpm run lint:spell && pnpm run validate:themes && pnpm run validate:marketplace && pnpm run test && pnpm run lint && pnpm run lint:knip && pnpm run package:extension",
    "pretest": "pnpm run build:themes",
    "test": "vitest run",
    "sync:website-version": "node scripts/sync-website-version.mjs",
    "validate:themes": "pnpm --filter santi020k-theme run validate:themes",
    "validate:marketplace": "node scripts/check-marketplace-readiness.mjs",
    "lint": "eslint . --cache --no-warn-ignored",
    "lint:fix": "eslint . --cache --fix --no-warn-ignored",
    "lint:spell": "cspell \"**\" --gitignore --cache --show-suggestions --show-context",
    "lint:knip": "knip",
    "package": "pnpm run package:extension",
    "package:extension": "pnpm --filter santi020k-theme run package",
    "publish": "pnpm --filter santi020k-theme run publish",
    "release": "pnpm --filter santi020k-theme run release",
    "release:tag": "node scripts/ensure-release-tag.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --lockfile-only && pnpm run sync:website-version",
    "site:dev": "pnpm --filter @santi020k/santi020k-theme-website run dev",
    "site:build": "pnpm --filter @santi020k/santi020k-theme-website run build",
    "site:preview": "pnpm --filter @santi020k/santi020k-theme-website run preview",
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "pre-push": "pnpm run validate",
    "commit": "cz"
  },
  "devDependencies": {
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@santi020k/eslint-config-basic": "catalog:",
    "@types/node": "catalog:",
    "@vscode/vsce": "catalog:",
    "commitizen": "catalog:",
    "cspell": "catalog:",
    "cz-conventional-changelog": "catalog:",
    "eslint": "catalog:",
    "husky": "catalog:",
    "knip": "catalog:",
    "lint-staged": "catalog:",
    "ovsx": "catalog:",
    "turbo": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "lint-staged": {
    "*.{js,mjs}": [
      "eslint --fix --no-warn-ignored"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
