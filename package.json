{
  "name": "@santi020k/santi020k-theme-root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm run site:dev",
    "dev:vscode": "pnpm run build:themes",
    "dev:chrome": "pnpm --filter santi020k-chrome-theme run dev",
    "dev:chrome:dark": "pnpm --filter santi020k-chrome-theme run dev:dark",
    "dev:chrome:light": "pnpm --filter santi020k-chrome-theme run dev:light",
    "build": "turbo run build",
    "build:chrome-theme": "pnpm --filter santi020k-chrome-theme run build",
    "build:themes": "pnpm --filter santi020k-theme run build",
    "validate": "pnpm run build && pnpm run lint:spell && pnpm run validate:themes && pnpm run validate:marketplace && pnpm run validate:chrome && pnpm run validate:seo && pnpm run test && pnpm run lint && pnpm run lint:knip && pnpm run package:extension",
    "pretest": "pnpm run build:themes",
    "test": "vitest run packages/santi020k-theme/tests apps/vscode-website/tests",
    "sync:website-version": "pnpm --filter @santi020k/santi020k-vscode-theme-website run sync:website-version",
    "validate:links": "node scripts/check-website-links.mjs",
    "validate:seo": "node scripts/validate-website-seo.mjs",
    "validate:themes": "pnpm --filter santi020k-theme run validate:themes",
    "validate:marketplace": "pnpm --filter santi020k-theme run validate:marketplace",
    "validate:chrome": "pnpm --filter santi020k-chrome-theme run validate",
    "lint": "eslint . --cache --no-warn-ignored",
    "lint:fix": "eslint . --cache --fix --no-warn-ignored",
    "lint:spell": "cspell \"**\" --gitignore --cache --show-suggestions --show-context",
    "lint:knip": "knip",
    "package": "pnpm run package:extension",
    "package:extension": "pnpm --filter santi020k-theme run package",
    "package:chrome": "pnpm --filter santi020k-chrome-theme run package",
    "publish": "pnpm --filter santi020k-theme run publish",
    "publish:npm": "node scripts/publish-npm-packages.mjs",
    "publish:chrome": "pnpm --filter santi020k-chrome-theme run publish:webstore",
    "release": "pnpm run validate && pnpm run publish:npm && pnpm --filter santi020k-theme run release",
    "release:npm": "pnpm run publish:npm",
    "release:chrome": "pnpm --filter santi020k-chrome-theme run release",
    "release:tag": "pnpm --filter santi020k-theme run release:tag",
    "generate:og": "node scripts/generate-og-images.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm --filter santi020k-chrome-theme run sync:manifest-version && pnpm install --lockfile-only && pnpm run sync:website-version",
    "site:dev": "pnpm --filter @santi020k/santi020k-theme-website run dev",
    "site:build": "pnpm --filter @santi020k/santi020k-theme-website run build",
    "site:preview": "pnpm --filter @santi020k/santi020k-theme-website run preview",
    "site:vscode:dev": "pnpm --filter @santi020k/santi020k-vscode-theme-website run dev",
    "site:vscode:build": "pnpm --filter @santi020k/santi020k-vscode-theme-website run build",
    "site:vscode:preview": "pnpm --filter @santi020k/santi020k-vscode-theme-website run preview",
    "site:chrome:dev": "pnpm --filter @santi020k/santi020k-chrome-theme-website run dev",
    "site:chrome:build": "pnpm --filter @santi020k/santi020k-chrome-theme-website run build",
    "site:chrome:preview": "pnpm --filter @santi020k/santi020k-chrome-theme-website run preview",
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "pre-push": "pnpm run validate",
    "commit": "cz"
  },
  "devDependencies": {
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@santi020k/eslint-config-basic": "catalog:",
    "@types/node": "catalog:",
    "@vscode/vsce": "catalog:",
    "commitizen": "catalog:",
    "cspell": "catalog:",
    "cz-conventional-changelog": "catalog:",
    "eslint": "catalog:",
    "husky": "catalog:",
    "knip": "catalog:",
    "lint-staged": "catalog:",
    "ovsx": "catalog:",
    "sharp": "catalog:",
    "turbo": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "lint-staged": {
    "*.{js,mjs}": [
      "eslint --fix --no-warn-ignored"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
