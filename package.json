{
  "name": "santi020k-theme",
  "displayName": "santi020k Theme",
  "description": "Dark and light themes with a deep indigo-black palette and muted violet accents — inspired by the Antigravity wallpaper.",
  "version": "1.2.1",
  "publisher": "santi020k",
  "author": {
    "name": "Santiago Molina",
    "url": "https://santi020k.com"
  },
  "homepage": "https://theme.santi020k.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/santi020k/santi020k-theme"
  },
  "bugs": {
    "url": "https://github.com/santi020k/santi020k-theme/issues"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": true
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "dark",
    "light",
    "purple",
    "indigo",
    "antigravity",
    "santi020k"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#120c1e",
    "theme": "dark"
  },
  "contributes": {
    "themes": [
      {
        "label": "santi020k dark",
        "uiTheme": "vs-dark",
        "path": "./themes/santi020k-dark-color-theme.json"
      },
      {
        "label": "santi020k light",
        "uiTheme": "vs",
        "path": "./themes/santi020k-light-color-theme.json"
      }
    ]
  },
  "scripts": {
    "validate": "npm run validate:themes && npm run validate:marketplace && npm run test && npm run lint && npm run site:install && npm run site:build && npm run package -- --no-dependencies",
    "test": "vitest run",
    "validate:themes": "node scripts/validate-themes.mjs",
    "validate:marketplace": "node scripts/check-marketplace-readiness.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "package": "vsce package",
    "publish": "node scripts/publish-registries.mjs",
    "publish:pre": "npm run validate && vsce publish --pre-release",
    "release": "node scripts/publish-registries.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version && npm install --package-lock-only",
    "site:install": "npm --prefix website ci",
    "site:dev": "cd website && npm run dev",
    "site:build": "cd website && npm run build",
    "site:preview": "cd website && npm run preview"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@santi020k/eslint-config-basic": "^1.6.0",
    "@types/node": "^22.19.17",
    "@vscode/vsce": "^3.9.1",
    "ovsx": "^0.10.11",
    "vitest": "^3.2.4"
  }
}
